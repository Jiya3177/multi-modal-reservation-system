<%- include('../partials/header') %>

<section class="container page-section">
  <div class="section-head section-head-tight">
    <div>
      <p class="eyebrow">Search Results</p>
      <h1><%= type.toUpperCase() %> options matched to your request</h1>
      <% if (type === 'hotel') { %>
        <p class="subtext">Destination city <strong><%= filters.destination || 'N/A' %></strong> • Check-in <strong><%= filters.date || 'N/A' %></strong> • Check-out <strong><%= filters.checkOutDate || 'N/A' %></strong></p>
      <% } else { %>
        <p class="subtext"><strong><%= filters.source || 'N/A' %></strong> to <strong><%= filters.destination || 'N/A' %></strong> • Travel date <strong><%= filters.date || 'N/A' %></strong></p>
      <% } %>
    </div>
    <a href="/" class="btn btn-ghost">Modify Search</a>
  </div>

  <% if (searchMeta && searchMeta.note) { %>
    <div class="info-banner"><strong><%= searchMeta.mode %></strong> mode active. <%= searchMeta.note %></div>
  <% } %>

  <div class="result-layout">
    <aside class="filter-sidebar card-glass reveal">
      <h3>Request Summary</h3>
      <ul class="summary-list">
        <li><span>Booking type</span><strong><%= type %></strong></li>
        <li><span>Budget</span><strong>INR <%= filters.maxPrice || 'N/A' %></strong></li>
        <li><span>Travelers</span><strong><%= filters.people || '1' %></strong></li>
        <li><span>Class / room</span><strong><%= filters.classType || 'Any' %></strong></li>
        <li><span>Minimum rating</span><strong><%= filters.minRating || '0' %>+</strong></li>
      </ul>
      <p class="subtext">These cards keep the existing booking links and identifiers, so you can continue into checkout without changing the backend flow.</p>
    </aside>

    <div class="result-grid-v2">
      <% if (!results.length) { %>
        <article class="card-glass empty-state">
          <h3>No options found for the current filters</h3>
          <p>Try another date, a higher budget, or a broader class filter to widen the search.</p>
          <a href="/" class="btn">Back to Search</a>
        </article>
      <% } %>

      <% results.forEach(item => { %>
        <article class="card-glass result-card-v2 reveal">
          <% if (type === 'hotel') { %>
            <div class="result-head">
              <h3><span class="type-icon">🏨</span> <%= item.hotel_name %></h3>
              <span class="pill-badge">⭐ <%= item.rating %></span>
            </div>
            <p class="route-line"><strong><%= item.city_name %></strong> • <%= item.room_type %></p>
            <p class="subtext"><%= item.amenities %></p>
            <div class="result-meta">
              <span><%= item.available_rooms %>/<%= item.total_rooms %> rooms available</span>
              <span>Instant confirmation after payment</span>
            </div>
            <div class="result-foot">
              <div>
                <strong class="price-main">INR <%= item.price_per_night %></strong>
                <small>per night</small>
              </div>
              <a class="btn" href="/booking/hotel/<%= item.hotel_id %>?people=<%= filters.people || 1 %>&date=<%= encodeURIComponent(filters.date || '') %>&checkOut=<%= encodeURIComponent(filters.checkOutDate || '') %>">Reserve</a>
            </div>
          <% } else { %>
            <div class="result-head">
              <h3><span class="type-icon"><%= type === 'flight' ? '✈' : type === 'train' ? '🚆' : '🚌' %></span> <%= item.operator_name %></h3>
              <span class="pill-badge"><%= item.code %></span>
            </div>
            <p class="route-line"><strong><%= item.source_city %></strong> to <strong><%= item.destination_city %></strong></p>
            <p class="subtext"><%= item.depart_time %> to <%= item.arrive_time %> • <%= item.class_type %> • ⭐ <%= item.rating %></p>
            <div class="result-meta">
              <span><%= item.available_seats %>/<%= item.total_seats %> seats available</span>
              <span><%= item.travel_date %></span>
            </div>
            <div class="result-foot">
              <div>
                <strong class="price-main">INR <%= item.price %></strong>
                <small>per seat</small>
              </div>
              <a class="btn" href="/booking/<%= type %>/<%= item[type + '_id'] %>?people=<%= filters.people || 1 %>">Select</a>
            </div>
          <% } %>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
