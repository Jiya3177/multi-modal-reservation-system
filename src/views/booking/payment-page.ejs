<%- include('../partials/header') %>

<section class="container page-section">
  <div
    class="upi-flow"
    id="upiPaymentFlow"
    data-booking-id="<%= booking.booking_id %>"
    data-booking-type="<%= booking.booking_type %>"
    data-reservation-id="<%= booking.reservation_id %>"
    data-amount="<%= booking.total_price %>"
    data-merchant-name="<%= merchantName %>"
    data-upi-id="<%= upiId %>"
    data-expiry-minutes="<%= otpExpiryMinutes %>"
  >
    <article class="upi-panel upi-panel-primary card-glass reveal">
      <div class="upi-brand-row">
        <div>
          <p class="eyebrow">UPI Payment</p>
          <h1>Complete your reservation with secure UPI checkout.</h1>
        </div>
        <span class="upi-badge">UPI</span>
      </div>

      <div class="upi-summary-grid">
        <div class="upi-summary-card">
          <span>Merchant</span>
          <strong><%= merchantName %></strong>
        </div>
        <div class="upi-summary-card">
          <span>Booking ID</span>
          <strong><%= booking.reservation_id %></strong>
        </div>
        <div class="upi-summary-card">
          <span>Amount</span>
          <strong>INR <%= booking.total_price %></strong>
        </div>
        <div class="upi-summary-card">
          <span>Wallet Balance</span>
          <strong id="walletBalanceDisplay">INR <%= Number(wallet.balance).toFixed(2) %></strong>
        </div>
      </div>

      <div class="upi-step-shell">
        <section class="upi-step upi-step-active" data-step="scan">
          <div class="upi-qr-card">
            <div id="upiQrCode" class="upi-qr-box" aria-label="UPI QR code"></div>
            <div class="upi-qr-details">
              <p><strong>UPI ID:</strong> <span id="upiIdLabel"><%= upiId %></span></p>
              <p><strong>Booking:</strong> <%= booking.booking_type.toUpperCase() %></p>
              <p><strong>Seats / Rooms:</strong> <%= bookingSeats.map((item) => item.seat_label).join(', ') %></p>
              <p class="upi-countdown">Expires in <strong id="upiCountdown">05:00</strong></p>
            </div>
          </div>

          <div class="upi-action-card">
            <p class="subtext">Scan the QR code or continue below to approve this UPI payment.</p>
            <label>
              Confirm Login Password
              <input type="password" id="paymentPasswordInput" placeholder="Enter your login password" required />
            </label>
            <p class="upi-inline-note">You get 3 password attempts. After that, the pending booking is cancelled automatically.</p>
            <button type="button" class="btn btn-full upi-pay-btn" id="simulatePaymentBtn">Pay via UPI</button>
            <p class="upi-inline-note">Wallet balance is deducted after payment confirmation.</p>
          </div>
        </section>

        <section class="upi-step" data-step="otp">
          <div class="upi-otp-card">
            <p class="eyebrow">OTP Verification</p>
            <h2>OTP sent to registered mobile</h2>
            <p class="subtext">Enter the 6-digit OTP sent to your booking mobile number to approve payment.</p>

            <div class="otp-input-row" id="otpInputRow">
              <% for (let i = 0; i < 6; i += 1) { %>
                <input type="text" inputmode="numeric" maxlength="1" class="otp-digit" />
              <% } %>
            </div>

            <button type="button" class="btn btn-full" id="verifyOtpBtn">Verify OTP</button>
          </div>
        </section>

        <section class="upi-step" data-step="success">
          <div class="upi-success-card">
            <div class="success-anim success-anim-green" aria-hidden="true">
              <i>✓</i>
            </div>
            <h2>Payment Successful</h2>
            <p class="subtext">Your booking is now confirmed and saved to the database.</p>
            <div class="upi-success-grid">
              <div><span>Transaction ID</span><strong id="successTransactionId">-</strong></div>
              <div><span>Amount</span><strong id="successAmount">-</strong></div>
              <div><span>Time</span><strong id="successTime">-</strong></div>
              <div><span>Wallet Left</span><strong id="successWalletBalance">-</strong></div>
            </div>
            <div class="action-row">
              <a href="/booking/history" class="btn">Open History</a>
              <a href="/booking/history/<%= booking.booking_id %>" class="btn btn-ghost">View Receipt</a>
            </div>
          </div>
        </section>
      </div>

      <p class="upi-feedback" id="upiFeedback" aria-live="polite"></p>
    </article>
  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<%- include('../partials/footer') %>
