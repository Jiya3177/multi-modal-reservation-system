<%- include('../partials/header') %>

<section class="container auth-shell">
  <article class="auth-side card-glass reveal">
    <p class="eyebrow">Password Assistance</p>
    <h1>Recover account access with a verification code.</h1>
    <p class="subtext">Submit your registered email and we will send a 6-digit code that you can enter on the website to reset your password.</p>
    <div class="auth-points">
      <span>Traveler account recovery</span>
      <span>Secure reset path</span>
      <span>Minimal interruption to bookings</span>
    </div>
  </article>

  <form class="auth-form card-glass reveal" action="/auth/forgot-password" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <h2>Forgot Password</h2>
    <% if (error) { %><p class="field-error"><%= error %></p><% } %>
    <% if (message) { %><p class="field-success"><%= message %></p><% } %>

    <label>Email
      <input type="email" name="email" required />
    </label>
    <button class="btn btn-full" type="submit">Send Verification Code</button>
  </form>
</section>

<%- include('../partials/footer') %>
