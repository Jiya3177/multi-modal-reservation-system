<%- include('../partials/header') %>

<section class="container auth-shell">
  <article class="auth-side card-glass reveal">
    <p class="eyebrow">Reset Password</p>
    <h1>Enter your email code and choose a new password.</h1>
    <p class="subtext">The verification code sent to your email expires automatically after a short time and can only be used once.</p>
    <div class="auth-points">
      <span>6-digit email verification</span>
      <span>30-minute expiry window</span>
      <span>Secure password hashing</span>
    </div>
  </article>

  <form class="auth-form card-glass reveal" action="/auth/reset-password" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
    <h2>Set New Password</h2>
    
    <% if (typeof error !== 'undefined' && error) { %><p class="field-error"><%= error %></p><% } %>
    <% if (typeof message !== 'undefined' && message) { %><p class="field-success"><%= message %></p><% } %>
    
    <label>Email Address
      <input type="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required <%= typeof email !== 'undefined' && email ? 'readonly style="background:#f0f0f0; cursor:not-allowed;"' : '' %> />
    </label>
    <label>6-Digit Verification Code
      <input type="text" name="verificationCode" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" required autofocus />
    </label>

    <label>New Password
      <input type="password" name="password" minlength="6" required />
    </label>
    <label>Confirm Password
      <input type="password" name="confirmPassword" minlength="6" required />
    </label>
    <button class="btn btn-full" type="submit">Update Password</button>
  </form>
</section>

<%- include('../partials/footer') %>
