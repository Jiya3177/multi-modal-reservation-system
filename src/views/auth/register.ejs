<%- include('../partials/header') %>

<section class="container auth-shell">
  <article class="auth-side card-glass reveal">
    <p class="eyebrow">Create Traveler Account</p>
    <h1>Register once and manage every booking mode from one profile.</h1>
    <p class="subtext">Your account connects reservations, notifications, payment confirmations, and cancellation history.</p>
    <div class="auth-points">
      <span>Single profile for all bookings</span>
      <span>Trip history and notifications</span>
      <span>Fast checkout continuation</span>
    </div>
  </article>

  <form class="auth-form card-glass reveal" action="/auth/register" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <h2>Register</h2>
    <% if (error) { %><p class="field-error"><%= error %></p><% } %>
    <label>Full Name
      <input name="full_name" required />
    </label>
    <label>Email
      <input type="email" name="email" required />
    </label>
    <label>Phone (10 digits)
      <input name="phone" pattern="\d{10}" required />
    </label>
    <label>Password
      <input type="password" name="password" minlength="6" required />
    </label>
    <button class="btn btn-full" type="submit">Create Account</button>
  </form>
</section>

<%- include('../partials/footer') %>
