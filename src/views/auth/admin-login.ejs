<%- include('../partials/header') %>

<section class="container auth-shell">
  <article class="auth-side card-glass reveal">
    <p class="eyebrow">Operations Access</p>
    <h1>Access the separate admin workspace for users, wallets, bookings, and inventory.</h1>
    <p class="subtext">Use this admin login to open the operations panel, review user-wise booking history, and add wallet money when needed.</p>
    <div class="auth-points">
      <span>Inventory oversight</span>
      <span>Payment monitoring</span>
      <span>User wallet control</span>
    </div>
  </article>

  <form class="auth-form card-glass reveal" action="/auth/admin/login" method="POST" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <h2>Admin Login</h2>
    <% if (error) { %><p class="field-error"><%= error %></p><% } %>
    <label>Email
      <input type="email" name="email" required />
    </label>
    <label>Password
      <input type="password" name="password" required />
    </label>
    <button class="btn btn-full" type="submit">Login as Admin</button>
  </form>
</section>

<%- include('../partials/footer') %>
